{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/main.css",
      "destination": "/main.css"
    },
    {
      "source": "/app.js",
      "destination": "/app.js"
    },
    {
      "source": "/((?!main\\.css|app\\.js|api/).*)",
      "destination": "/index.html"
    }
  ]
}
